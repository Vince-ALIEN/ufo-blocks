{
  "apiVersion": 3,
  "name": "ufo-blocks/ufo-icon",
  "title": "UFO Icon",
  "category": "ufo-blocks",
  "icon": "star-filled",
  "description": "Affiche une icône Lucide avec alignement et couleur du thème.",
  "supports": {
    "html": false,
    "anchor": true,
    "textAlign": true,
    "color": {
      "text": true,
      "background": true,
      "__experimentalDefaultControls": {
        "text": true
      }
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "__experimentalDefaultControls": {
        "margin": false,
        "padding": false
      }
    }
  },
  "attributes": {
    "icon": {
      "type": "string",
      "default": ""
    },
    "iconSize": {
      "type": "number",
      "default": 32
    },
    "textAlign": {
      "type": "string",
      "default": "left"
    }
  },
  "textdomain": "ufo-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php"
}
